<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SVOI | Копчення до Великодня</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #111;
    color: #fff;
    text-align: center;
}

header {
    padding: 40px 20px;
    background: linear-gradient(45deg, #ff6a00, #ff0000);
}

h1 {
    margin: 0;
    font-size: 42px;
    letter-spacing: 2px;
}

.subtitle {
    font-size: 18px;
    margin-top: 10px;
}

.container {
    padding: 30px 15px;
}

.card {
    background: #1c1c1c;
    margin: 15px auto;
    padding: 20px;
    border-radius: 15px;
    max-width: 400px;
    box-shadow: 0 0 20px rgba(255,0,0,0.2);
}

.price {
    color: #ff6a00;
    font-size: 20px;
    margin-top: 10px;
}

button {
    margin-top: 15px;
    padding: 12px 25px;
    border: none;
    border-radius: 10px;
    background: #ff0000;
    color: white;
    font-size: 16px;
    cursor: pointer;
}

button:hover {
    background: #ff6a00;
}

footer {
    margin-top: 40px;
    padding: 20px;
    font-size: 14px;
    color: #aaa;
}
</style>
</head>

<body>

<header>
    <h1>🔥 SVOI 🔥</h1>
    <div class="subtitle">Копчення до Великодня 🐣</div>
</header>

<div class="container">

    <div class="card">
        <h2>🥩 Курочка</h2>
        <div class="price">250 грн/кг</div>
        <button onclick="order()">Замовити</button>
    </div>

    <div class="card">
        <h2>🥩 Свинячі реберця</h2>
        <div class="price">470 грн/кг</div>
        <button onclick="order()">Замовити</button>
    </div>

    <div class="card">
        <h2>🥩 Сало</h2>
        <div class="price">450 грн/кг</div>
        <button onclick="order()">Замовити</button>
    </div>

    <div class="card">
        <h2>🥩 Балик</h2>
        <div class="price">500 грн/кг</div>
        <button onclick="order()">Замовити</button>
    </div>

    <div class="card">
        <h2>🥩 Підчеревина</h2>
        <div class="price">450 грн/кг</div>
        <button onclick="order()">Замовити</button>
    </div>

</div>

<footer>
    📦 Замовлення приймаються в Direct / Telegram  
</footer>

<script>
function order() {
    window.location.href = "https://t.me/yourusername";
}
</script>

</body>
</html>
